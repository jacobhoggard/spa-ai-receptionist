# ============================================================================
# AI RECEPTIONIST SERVER - Environment Variables
# ============================================================================
# Production configuration for Sanctuary Day Spa

# ============================================================================
# SERVER
# ============================================================================
PORT=3000
NODE_ENV=production

# WebSocket URL for ConversationRelay (your server's public URL)
WEBSOCKET_URL=wss://spa-ai-receptionist-production.up.railway.app

# ============================================================================
# TWILIO
# ============================================================================
TWILIO_ACCOUNT_SID=AC5c6S797bb8b3t4457edcc2bc69f7fa14
TWILIO_AUTH_TOKEN=your_auth_token_from_twilio_console
TWILIO_PHONE_NUMBER=+64 3 668 1200

# Where to transfer escalated calls (human agent phone number)
HUMAN_QUEUE_NUMBER=+64 3 668 1200

# ============================================================================
# EMAIL CONFIGURATION - GMAIL FALLBACK
# ============================================================================
# System uses Gmail SMTP with fallback to local file storage
# If both fail, bookings are saved to /bookings/*.json for manual processing

# Gmail credentials for SMTP fallback (required for email delivery)
# To get an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Email configuration for booking notifications
EMAIL_FROM_ADDRESS=info@sanctuarywanaka.co.nz
EMAIL_FROM_NAME=Sanctuary Day Spa
EMAIL_TO_ADDRESS=info@sanctuarywanaka.co.nz

# ============================================================================
# CLINIKO (Booking System)
# ============================================================================
CLINIKO_API_KEY=your_cliniko_api_key_here
CLINIKO_BUSINESS_ID=your_cliniko_business_id_here

# ============================================================================
# DATABASE (PostgreSQL) - Optional for production
# ============================================================================
DATABASE_URL=

# ============================================================================
# REDIS (Session State) - Optional for production
# ============================================================================
REDIS_URL=

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
DEBUG_CONVERSATION_ENGINE=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_EMAIL_SMS_FALLBACK=true
ENABLE_CALL_RECORDING=true
ENABLE_TRANSCRIPTION=true

# ============================================================================
# NZ-SPECIFIC SETTINGS
# ============================================================================
TIMEZONE=Pacific/Auckland
SMS_COMPLIANCE_MODE=true
PII_RETENTION_DAYS=30

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
SKIP_TWILIO_AUTH=false
USE_MOCK_CLINIKO=false
