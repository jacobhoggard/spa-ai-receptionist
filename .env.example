# ============================================================================
# AI RECEPTIONIST SERVER - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# Keep .env PRIVATE (add to .gitignore)

# ============================================================================
# SERVER
# ============================================================================
PORT=3000
NODE_ENV=development

# WebSocket URL for ConversationRelay (your server's public URL)
# During local dev: ws://localhost:3000
# In production: wss://your-domain.com
WEBSOCKET_URL=ws://localhost:3000

# ============================================================================
# ELEVENLABS (Text-to-Speech for Ava's voice)
# ============================================================================
# Get API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID — find this in the ElevenLabs voice library URL or voice settings
ELEVENLABS_VOICE_ID=your_voice_id_here

# Your public server URL (used to serve audio to Twilio)
# Railway example: https://spa-ai-receptionist-production.up.railway.app
BASE_URL=https://your-railway-app.up.railway.app

# ============================================================================
# TWILIO
# ============================================================================
# Get these from https://www.twilio.com/console

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+64991234567

# Where to transfer escalated calls (human agent phone number)
HUMAN_QUEUE_NUMBER=+64991235000

# ============================================================================
# CLINIKO (Booking System)
# ============================================================================
# Get API key from Cliniko settings
# https://www.cliniko.com/settings/api-tokens

CLINIKO_API_KEY=your_cliniko_api_key_here
CLINIKO_BUSINESS_ID=your_cliniko_business_id_here

# ============================================================================
# GMAIL (Email notifications to Sanctuary team)
# ============================================================================
# Gmail account to send FROM (e.g. a dedicated gmail like ava@gmail.com)
GMAIL_USER=your.gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Go to: Google Account → Security → 2-Step Verification → App passwords
# Create an app password for "Mail" and paste it here
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Example for development: postgresql://user:password@localhost:5432/receptionist_dev
# In production, use managed database (AWS RDS, Heroku Postgres, etc.)

DATABASE_URL=postgresql://user:password@localhost:5432/receptionist_dev

# ============================================================================
# REDIS (Session State)
# ============================================================================
# For development: redis://localhost:6379
# In production: Redis cluster with TLS

REDIS_URL=redis://localhost:6379

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Optional: SendGrid event webhook for delivery tracking
SENDGRID_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable email SMS fallback (if email capture fails after 2 attempts)
ENABLE_EMAIL_SMS_FALLBACK=true

# Enable call recording (Twilio records by default)
ENABLE_CALL_RECORDING=true

# Enable conversation transcription (speech-to-text)
ENABLE_TRANSCRIPTION=true

# ============================================================================
# NZ-SPECIFIC SETTINGS
# ============================================================================
# Timezone for business hours (New Zealand)
TIMEZONE=Pacific/Auckland

# SMS compliance: Require opt-in before sending promotional SMS
SMS_COMPLIANCE_MODE=true

# Privacy: Anonymize PII in logs after N days
PII_RETENTION_DAYS=30

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Skip Twilio authentication (DEV ONLY - NEVER IN PRODUCTION)
SKIP_TWILIO_AUTH=false

# Use mock Cliniko API responses (for testing without real API key)
USE_MOCK_CLINIKO=false

# Print detailed debug logs
DEBUG_CONVERSATION_ENGINE=false
